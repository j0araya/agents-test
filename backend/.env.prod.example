# Production environment — NEVER commit this file.
# Copy from .env.prod.example and fill in real values.

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/chile_atlas?retryWrites=true&w=majority

# Server
PORT=3001

# CORS — set to your production frontend URL
CORS_ORIGIN=https://your-frontend-domain.com
